      "circuitBreakerEngine": {
        "type": "Tri-State Circuit Breaker (CLOSED / OPEN / HALF-OPEN)",
        "moduleScopeVariables": [
          "circuitState: CircuitState — starts CLOSED",
          "consecutiveExhaustedFailures: number — failure counter",
          "CIRCUIT_OPEN_THRESHOLD: 3 — failures before OPEN",
          "circuitHalfOpenTimerId: NodeJS.Timeout | null — OPEN→HALF-OPEN timer",
          "HALF_OPEN_DELAY_MS: 30000 — cooldown before probe attempt",
          "circuitOpenedAt: string | null — ISO timestamp of last OPEN"
        ],
        "transitions": {
          "CLOSED → OPEN": "consecutiveExhaustedFailures reaches CIRCUIT_OPEN_THRESHOLD (3)",
          "OPEN → HALF-OPEN": "After 30s cooldown via circuitHalfOpenTimerId",
          "HALF-OPEN → CLOSED": "recordSuccess() on any successful operation",
          "HALF-OPEN → OPEN": "recordExhaustedFailure() if probe fails"
        },
        "eventBroadcast": "EventBus.emit('CIRCUIT_BREAKER_STATE_CHANGED', { state, reason, timestamp, queueSize })",
        "exportedFunctions": ["enqueueOperation", "registerFlushExecutor", "getCircuitBreakerSnapshot", "CircuitState (type)", "QueuedOperation (interface)"],
        "manualOverride": "executeForcedCircuitOverride(targetState) — forces CLOSED (with Auto-Flush) or OPEN"
      },
      "inMemoryQueue": {
        "description": "FIFO array for offline operation storage during OPEN state",
        "moduleScopeVariables": [
          "inMemoryQueue: QueuedOperation[] — the queue array",
          "isFlushing: boolean — mutex guard against concurrent flushes",
          "FLUSH_EXECUTOR_MAP: Record<string, Function> — registered executors"
        ],
        "registeredExecutors": ["TRANSFER_TICKET → executeTransferTicket()", "BROADCAST_CONFIG → RealTimeSynchronizer.broadcast('CONFIG_UPDATED')"],
        "autoFlushTrigger": "scheduleAutoFlush() called from recordSuccess() when HALF-OPEN→CLOSED or upon Manual Override to CLOSED",
        "flushMechanism": "setImmediate() → flushQueue() — non-blocking FIFO drain",
        "flushBroadcast": "EventBus.emit('QUEUE_FLUSHED', { flushedCount, failedCount, remaining, timestamp })"
      },
